  return (
    <div className="ubp5">
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Baloo+2:wght@700;800&family=Hanken+Grotesque:wght@400;500;700&family=DM+Mono:wght@500&display=swap');
        .ubp5 {
          --ink: #17141F; --ink-soft: #615C70; --violet: #8B6CF6; --paper-2: #ECE9F7;
          --fd: 'Baloo 2', sans-serif; --fb: 'Hanken Grotesque', sans-serif; --fm: 'DM Mono', monospace;
          font-family: var(--fb); color: var(--ink);
        }
        .ubp5 *, .ubp5 *::before, .ubp5 *::after { box-sizing: border-box; margin: 0; padding: 0; }
        .ubp5 .kicker { font-family: var(--fm); font-size: 14px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--violet); margin-bottom: 22px; }
        .ubp5 h2 { font-family: var(--fd); font-weight: 800; text-transform: uppercase; letter-spacing: -0.01em; line-height: 0.98; font-size: clamp(36px, 5vw, 60px); }
        .ubp5 .sub { font-size: 19px; line-height: 1.55; color: var(--ink-soft); max-width: 560px; margin-top: 18px; }

        .ubp5 .faq { background: #fff; padding: 110px 28px; }
        .ubp5 .faq .inner { max-width: 820px; margin: 0 auto; }
        .ubp5 .qa { border-bottom: 1.5px solid var(--paper-2); }
        .ubp5 .qa summary {
          list-style: none; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 20px;
          font-family: var(--fd); font-weight: 700; font-size: 21px; padding: 24px 4px;
        }
        .ubp5 .qa summary::-webkit-details-marker { display: none; }
        .ubp5 .qa summary .pm { font-family: var(--fb); font-weight: 400; font-size: 26px; color: var(--violet); flex: none; transition: transform .25s; }
        .ubp5 .qa[open] summary .pm { transform: rotate(45deg); }
        .ubp5 .qa .a { padding: 0 4px 26px; font-size: 16.5px; line-height: 1.6; color: var(--ink-soft); max-width: 680px; }

        .ubp5 .final {
          text-align: center; background: linear-gradient(180deg, #FFFFFF 0%, #ECE9F7 100%);
          padding: 140px 28px 150px;
        }
        .ubp5 .final h2 { font-size: clamp(40px, 6vw, 72px); }
        .ubp5 .final .sub { margin: 20px auto 0; }
        .ubp5 .final .ubp5-cta { margin-top: 40px; }
        .ubp5 .ubp5-cta {
          font-family: var(--fb); font-weight: 700; font-size: 17px; color: #fff;
          background: linear-gradient(120deg, #8B6CF6 0%, #ED6CA8 100%);
          border: none; border-radius: 999px; cursor: pointer;
          padding: 16px 30px; display: inline-flex; align-items: center; gap: 9px;
          box-shadow: 0 12px 32px rgba(139,108,246,0.38); height: auto;
          transition: transform .18s ease, box-shadow .18s;
        }
        .ubp5 .ubp5-cta:hover { transform: translateY(-2px); box-shadow: 0 16px 40px rgba(139,108,246,0.45); }

        @media (max-width: 900px) {
          .ubp5 .faq { padding: 80px 24px; }
          .ubp5 .final { padding: 100px 24px 110px; }
        }
        @media (max-width: 560px) { .ubp5 .qa summary { font-size: 18px; } }
      `}</style>

