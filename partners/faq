// unboring partners — block 5: common questions + final cta
import { Button } from "@/components/ui/button";
import { ArrowRight } from "lucide-react";

const UBP5_PARTNER_URL = "/partner-with-us";

const UBP5_QAS = [
  ["how much does it cost?", "for dining and venues: \u00a32 to \u00a34 per member sent, charged only for those who check in via in-app tracking. if you're ever unhappy, we refund it. for curators: you set the price, we sell the tickets, you keep 90%."],
  ["do i need to change how i operate?", "not at all. our members are normal customers having a good night. for venues, we just need a dedicated area for the group. for curators, you submit experiences through your dashboard and we handle the rest."],
  ["what if i'm not happy with the group?", "we'll refund your fee, no questions asked. our members are sociable, they show up to spend time and money, and they're the kind of guests you want back."],
  ["how do members find my venue?", "we handle all the matching and logistics. members are invited to experiences at your venue through the app. they don't search for you, we send them to you."],
  ["what kind of feedback do i get?", "after every experience, a private dashboard with summarised highlights, things to improve, demographic insight, and individual comments from guests."],
  ["how often will you send people?", "that's up to you. you pick the dates and frequency. most partners start once or twice a month and build from there."],
  ["what makes unboring different from a promo group?", "unboring is a technology company. members take a personality test that sorts them into one of five archetypes, and we use it to send them to venues and experiences we know suit them. that means the people we send are more likely to love your place and come back."],
];

export default function Block() {
  const handlePartner = (e) => {
    e.preventDefault();
    if (typeof window !== "undefined" && window.Softr?.modal?.open) {
      window.Softr.modal.open(UBP5_PARTNER_URL);
      return;
    }
    window.location.href = UBP5_PARTNER_URL;
