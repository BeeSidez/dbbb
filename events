                {ev[2]} &middot; {ev[3]} &middot; {ev[4]}{city === "all" ? ", " + ev[0] : ""}
              </div>
              <InviteTag invite={ev[5]} avatarIndex={EVENTS.indexOf(ev)} />
            </div>
          ))}
        </div>

        <div className="ube-cta-wrap">
          <Button
            onClick={handleSignUp}
            className="ube-cta font-bold group"
            style={{
              background: "linear-gradient(120deg, #8B6CF6 0%, #ED6CA8 100%)",
              color: "#fff",
              boxShadow: "0 12px 32px rgba(139, 108, 246, 0.38)",
            }}
          >
            sign up
            <ArrowRight
              className="ml-2 group-hover:translate-x-1 transition-transform"
              style={{ width: 18, height: 18 }}
            />
          </Button>
        </div>
      </div>
    </section>
  );
}
