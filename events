    const t = trackRef.current;
    if (!t) return;
    const target = Math.max(0, t.scrollLeft + dir * t.clientWidth * 0.9);
    t.scrollTo({ left: target, behavior: "smooth" });
    // fallback for environments where smooth scrolling stalls (frozen webviews, embeds)
    const before = t.scrollLeft;
